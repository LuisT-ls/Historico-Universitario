rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user profile is public
    function isPublic(userId) {
      let data = get(/databases/$(database)/documents/users/$(userId)).data;
      return 'settings' in data && 'privacy' in data.settings && data.settings.privacy == 'public';
    }

    // Helper function to check if a user's schedule is public
    function isSchedulePublic(userId) {
      let data = get(/databases/$(database)/documents/users/$(userId)).data;
      return 'settings' in data && 'schedulePrivacy' in data.settings && data.settings.schedulePrivacy == 'public';
    }

    // Helper para marcar campos obrigatorios e tipos
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Regras para a coleção 'users'
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) ||
                     ('settings' in resource.data && 'privacy' in resource.data.settings && resource.data.settings.privacy == 'public') ||
                     ('settings' in resource.data && 'schedulePrivacy' in resource.data.settings && resource.data.settings.schedulePrivacy == 'public');
      allow write: if request.auth != null && request.auth.uid == userId 
                    && isValidString(request.resource.data.name, 1, 100);
    }
    
    // Regras para a coleção 'disciplines'
    match /disciplines/{disciplineId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId) ||
                     isSchedulePublic(resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200);
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200)
                    && request.resource.data.ch is number
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Regras para a coleção 'certificados'
    match /certificados/{certificadoId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300);
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300)
                    && request.resource.data.cargaHoraria is number
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Retorna true se o usuário autenticado está apenas adicionando a si mesmo à lista de membros
    function onlyAddingSelf() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let newMembers = request.resource.data.members;
      let oldMembers = resource.data.members;
      return affectedKeys.hasOnly(['members', 'updatedAt'])
        && newMembers.hasAll(oldMembers)
        && newMembers.size() == oldMembers.size() + 1
        && newMembers.removeAll(oldMembers).hasOnly([request.auth.uid]);
    }

    // Regras para o módulo de Grupos
    match /groups/{groupId} {
      // Leitura pública para usuários autenticados: necessário para busca por código de convite
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      // Membros podem atualizar o grupo; não-membros só podem adicionar a si mesmos (via código de convite)
      allow update: if request.auth != null && (request.auth.uid in resource.data.members || onlyAddingSelf());
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      match /materials/{materialId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
      
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    // Bloqueio Global
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 