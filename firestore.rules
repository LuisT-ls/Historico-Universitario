rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user profile is public
    function isPublic(userId) {
      let data = get(/databases/$(database)/documents/users/$(userId)).data;
      return 'settings' in data && 'privacy' in data.settings && data.settings.privacy == 'public';
    }

    // Helper function to check if a user's schedule is public
    function isSchedulePublic(userId) {
      let data = get(/databases/$(database)/documents/users/$(userId)).data;
      return 'settings' in data && 'schedulePrivacy' in data.settings && data.settings.schedulePrivacy == 'public';
    }

    // Helper para marcar campos obrigatorios e tipos
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Regras para a coleção 'users'
    match /users/{userId} {
      // Leitura permitida para:
      // 1. Usuário autenticado (próprio perfil ou perfis de colegas de grupo)
      // 2. Visitante não autenticado que acessa um perfil marcado como público
      // 3. Visitante não autenticado que acessa uma grade de horários pública
      allow read: if request.auth != null
                  || (resource.data.settings.privacy == 'public')
                  || (resource.data.settings.schedulePrivacy == 'public');

      // Escrita restrita ao próprio usuário autenticado.
      // A validação de campos obrigatórios é feita na camada de aplicação.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras para a coleção 'disciplines'
    match /disciplines/{disciplineId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId) ||
                     isSchedulePublic(resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200);
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200)
                    && request.resource.data.ch is number
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Regras para a coleção 'certificados'
    match /certificados/{certificadoId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300);
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300)
                    && request.resource.data.cargaHoraria is number
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Retorna true se o usuário autenticado está apenas adicionando a si mesmo à lista de membros
    function onlyAddingSelf() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let newMembers = request.resource.data.members;
      let oldMembers = resource.data.members;
      return affectedKeys.hasOnly(['members', 'updatedAt'])
        && newMembers.hasAll(oldMembers)
        && newMembers.size() == oldMembers.size() + 1
        && newMembers.removeAll(oldMembers).hasOnly([request.auth.uid]);
    }

    // Regras para o módulo de Grupos
    match /groups/{groupId} {
      // Leitura pública para usuários autenticados: necessário para busca por código de convite
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      // Membros podem atualizar o grupo; não-membros só podem adicionar a si mesmos (via código de convite)
      allow update: if request.auth != null && (request.auth.uid in resource.data.members || onlyAddingSelf());
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      match /materials/{materialId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
      
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }

      match /presence/{userId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow write: if request.auth != null && request.auth.uid == userId
                     && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    // Helper para verificar se o usuário autenticado é admin
    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regras para a coleção 'materiais'
    match /materiais/{materialId} {
      // Leitura:
      //   - qualquer pessoa pode ler materiais aprovados
      //   - o próprio dono pode ler seus materiais (qualquer status)
      //   - admin pode ler tudo
      allow read: if resource.data.status == 'approved'
                  || (request.auth != null && request.auth.uid == resource.data.uploadedBy)
                  || isAdmin();

      // Criação: usuário autenticado, status 'approved' direto, downloadsCount = 0
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uploadedBy
                    && request.resource.data.status == 'approved'
                    && request.resource.data.downloadsCount == 0
                    && isValidString(request.resource.data.titulo, 3, 100)
                    && isValidString(request.resource.data.disciplina, 2, 100)
                    && isValidString(request.resource.data.curso, 1, 20)
                    && isValidString(request.resource.data.semestre, 5, 10)
                    && isValidString(request.resource.data.tipo, 1, 20);

      // Update:
      //   - admin pode alterar qualquer campo
      //   - dono pode editar apenas metadados (não pode mudar status, uploadedBy nem downloadsCount)
      //   - qualquer autenticado pode apenas incrementar downloadsCount em +1
      allow update: if isAdmin()
                    || (request.auth != null
                        && request.auth.uid == resource.data.uploadedBy
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['titulo', 'descricao', 'curso', 'disciplina', 'semestre', 'tipo', 'updatedAt'])
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.uploadedBy == resource.data.uploadedBy
                        && request.resource.data.downloadsCount == resource.data.downloadsCount)
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadsCount'])
                        && request.resource.data.downloadsCount == resource.data.downloadsCount + 1);

      // Delete: o próprio dono ou admin
      allow delete: if (request.auth != null && request.auth.uid == resource.data.uploadedBy)
                    || isAdmin();
    }

    // Bloqueio Global
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 