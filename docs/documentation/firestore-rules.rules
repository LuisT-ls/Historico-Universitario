rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user profile is public
    function isPublic(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.settings.privacy == 'public';
    }

    // Helper para validar strings obrigatórias
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Coleção 'users' — dados de perfil e configurações
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) ||
                     (resource.data.settings.privacy == 'public');
      allow write: if request.auth != null && request.auth.uid == userId
                    && isValidString(request.resource.data.name, 1, 100);
    }

    // Coleção 'disciplines' — histórico de disciplinas
    match /disciplines/{disciplineId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId);
      allow write: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200)
                    && request.resource.data.ch is number;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.nome, 1, 200);
    }

    // Coleção 'certificados' — atividades complementares
    match /certificados/{certificadoId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) ||
                     isPublic(resource.data.userId);
      allow write: if request.auth != null && request.auth.uid == resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300)
                    && request.resource.data.cargaHoraria is number;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId
                    && isValidString(request.resource.data.titulo, 1, 300);
    }

    // Bloqueio Global — negar acesso a qualquer outra coleção
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
